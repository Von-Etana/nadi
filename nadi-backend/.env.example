# ============================================
# Nadi Digital Service - Backend Configuration
# ============================================

NODE_ENV=production
PORT=5000
FRONTEND_URL=https://nadidigital.com

# Supabase Settings
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Flutterwave Payment Gateway
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_secret

# Termii SMS Configuration
TERMII_API_KEY=your_termii_api_key

# SendGrid Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key

# what3words Address API
WHAT3WORDS_API_KEY=your_what3words_api_key

# Reloadly API Configuration
RELOADLY_API_KEY=your_reloadly_client_secret
RELOADLY_CLIENT_ID=your_reloadly_client_id_optional
RELOADLY_SANDBOX=true

# Paystack (optional / fallback)
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...

LOG_LEVEL=info
